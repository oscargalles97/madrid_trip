# GROQ_API_KEY: Required for Groq chat/generation calls.
GROQ_API_KEY="MY_GROQ_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_CHAT_PASSWORD / CHAT_PASSWORD: Shared password that protects the whole app.
VITE_CHAT_PASSWORD="MY_APP_PASSWORD"

# GOOGLE_MAPS_API_KEY: Required for Google Places autocomplete when adding stops.
GOOGLE_MAPS_API_KEY="MY_GOOGLE_MAPS_API_KEY"
